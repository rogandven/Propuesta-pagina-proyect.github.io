---
import { enlacesNavegacion } from '../../data/propuesta';

interface Props {
  vistaActual?: 'propuesta' | 'presentacion';
  mostrarNavegacionSecciones?: boolean;
}

const { vistaActual = 'propuesta', mostrarNavegacionSecciones = true } = Astro.props;
const logoUbbike = `${import.meta.env.BASE_URL}imagenes/ubbike-logo-transparente.png`;
const enlacePropuesta = `${import.meta.env.BASE_URL}`;
const enlacePresentacion = `${import.meta.env.BASE_URL}presentacion/`;
---

<header class="site-header">
  <div class="container nav-top">
    <a class="brand" href={enlacePropuesta}>
      <!-- 
      <img class="brand-logo" src={logoUbbike} alt="Logo UBBike" loading="eager" decoding="async" />
      -->
    </a>

    <nav class="modos-app" aria-label="Apartados principales del sitio">
      <a class:list={['modo-link', vistaActual === 'propuesta' && 'is-active']} href={enlacePropuesta}>
        Propuesta
      </a>
      <a class:list={['modo-link', vistaActual === 'presentacion' && 'is-active']} href={enlacePresentacion}>
        Presentacion UBBike
      </a>
    </nav>

    {mostrarNavegacionSecciones && (
      <button
        type="button"
        class="btn-nav-toggle"
        data-toggle-nav
        aria-controls="nav-secciones"
        aria-expanded="true"
      >
        Ocultar secciones
      </button>
    )}
  </div>

  {
    mostrarNavegacionSecciones && (
      <div class="container nav-collapsible" id="nav-secciones">
        <nav aria-label="Secciones">
          {enlacesNavegacion.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </nav>
      </div>
    )
  }
</header>

<script>
  const header = document.querySelector('.site-header');
  const boton = document.querySelector('[data-toggle-nav]');
  const panel = document.getElementById('nav-secciones');

  if (header && boton && panel) {
    const aplicarEstado = (colapsado : any) => {
      header.classList.toggle('is-collapsed', colapsado);
      boton.textContent = colapsado ? 'Mostrar secciones' : 'Ocultar secciones';
      boton.setAttribute('aria-expanded', String(!colapsado));
    };

    boton.addEventListener('click', () => {
      const colapsadoActual = header.classList.contains('is-collapsed');
      aplicarEstado(!colapsadoActual);
    });

    panel.querySelectorAll('a').forEach((enlace) => {
      enlace.addEventListener('click', () => {
        if (window.matchMedia('(max-width: 980px)').matches) {
          aplicarEstado(true);
        }
      });
    });

    if (window.matchMedia('(max-width: 980px)').matches) {
      aplicarEstado(true);
    }
  }
</script>
