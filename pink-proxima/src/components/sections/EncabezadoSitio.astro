---
import { enlacesNavegacion } from '../../data/propuesta';

const logoUbbike = `${import.meta.env.BASE_URL}imagenes/ubbike-logo-transparente.png`;
---

<header class="site-header">
  <div class="container nav">
    <a class="brand" href="#inicio">
      <img class="brand-logo" src={logoUbbike} alt="Logo UBBike" loading="eager" decoding="async" />
    </a>

    <nav aria-label="Secciones">
      {enlacesNavegacion.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>
  </div>
</header>
