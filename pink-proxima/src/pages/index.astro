---
import Layout from '../layouts/Layout.astro';

const painPoints = [
  'Registro manual en papel y filas en horarios de alta demanda.',
  'Error humano en datos de ingreso y salida.',
  'Sin trazabilidad centralizada por usuario, bicicleta y guardia.',
  'Dependencia total del guardia presente en el sector.',
];

const workflow = [
  'El usuario se registra una sola vez y asocia su bicicleta.',
  'La app genera un QR para el control de ingreso y retiro.',
  'El guardia valida visualmente y escanea para confirmar la operacion.',
  'El sistema guarda fecha, hora, usuario, bicicleta y estado de seguridad.',
  'Administracion consulta historial, incidencias y uso en tiempo real.',
];

const modules = [
  'Registro de usuarios',
  'Registro de bicicletas',
  'Generacion de codigo QR',
  'Validacion por guardia',
  'Control de estado por bicicletero',
  'Operacion de respaldo sin QR',
  'Historial de movimientos',
  'Gestion de incidencias',
  'Reportes de demanda y trazabilidad',
];

const actors = [
  {
    role: 'Estudiantes y funcionarios',
    action: 'Registran su perfil, asocian bicicleta y generan QR de acceso.',
    value: 'Acceso mas rapido y menos repeticion de datos.',
  },
  {
    role: 'Guardias de bicicletero',
    action: 'Validan visualmente, escanean QR y aplican respaldo manual cuando corresponda.',
    value: 'Control estandarizado con menor carga operativa.',
  },
  {
    role: 'Administracion universitaria',
    action: 'Consulta historial, incidencias, capacidad y trazabilidad por periodo.',
    value: 'Datos para seguimiento y toma de decisiones.',
  },
  {
    role: 'Seguridad institucional',
    action: 'Monitorea eventos y revisa movimientos en situaciones excepcionales.',
    value: 'Mayor capacidad de respuesta y auditoria.',
  },
];

const businessRules = [
  'Toda bicicleta operativa en el sistema debe quedar asociada a un usuario registrado.',
  'El ingreso y retiro requieren validacion de guardia, incluso con uso de QR.',
  'Si el QR falla o no hay bateria, se activa respaldo manual por RUT, nombre o datos de bicicleta.',
  'Cada movimiento debe registrar fecha, hora, usuario, bicicleta, guardia y bicicletero.',
  'El sistema debe registrar la condicion de seguridad al momento del ingreso (con o sin candado/U-Lock).',
];

const architectureLayers = [
  {
    layer: 'Experiencia de usuario',
    description: 'Aplicacion movil para estudiantes/funcionarios y vista operativa para guardias.',
  },
  {
    layer: 'Servicios de negocio',
    description:
      'Logica de ingreso/retiro, validacion QR, respaldo manual, control de estados e incidencias.',
  },
  {
    layer: 'Trazabilidad y reportes',
    description:
      'Consolidacion de movimientos para historial, auditoria por guardia y analisis de demanda.',
  },
  {
    layer: 'Persistencia de datos',
    description:
      'Almacenamiento estructurado de usuarios, bicicletas, accesos, observaciones y alertas.',
  },
];

const proposedStack = [
  {
    block: 'Opcion 1 (prioridad alta)',
    option: 'Flutter + Dart',
    reason:
      'Primera alternativa por su madurez multiplataforma, velocidad de desarrollo y consistencia visual en Android/iOS.',
  },
  {
    block: 'Opcion 2 (prioridad media)',
    option: 'Expo React Native + JavaScript',
    reason:
      'Segunda alternativa por su ecosistema amplio y facilidad de integracion con librerias para funcionalidades moviles.',
  },
  {
    block: 'Opcion 3 (prioridad condicionada)',
    option: 'Kotlin Multiplatform',
    reason:
      'Tercera alternativa para evaluar reutilizacion de logica entre plataformas cuando los requisitos tecnicos lo justifiquen.',
  },
  {
    block: 'Criterio de seleccion',
    option: 'Decision final segun requisitos del sistema',
    reason:
      'La eleccion definitiva del stack dependera del analisis funcional, no funcional y de restricciones detectadas durante el proyecto.',
  },
];

const benchmark = [
  {
    name: 'UdeCMovil (U. de Concepcion)',
    model: 'QR integrado en app institucional + control automatizado',
    userCost: 'Sin costo para comunidad interna',
    fit: 'Integra muchas funciones universitarias, no se enfoca solo en operacion de bicicleteros.',
  },
  {
    name: 'UH Go + Bikeep (University of Houston)',
    model: 'App institucional conectada a racks inteligentes',
    userCost: 'Sin costo para estudiantes y staff',
    fit: 'Depende de infraestructura inteligente dedicada.',
  },
  {
    name: 'UC Davis Bicycle Program',
    model: 'Lockers y bike cages con modalidad de arriendo',
    userCost: 'Tarifado por deposito y mensualidad',
    fit: 'El foco es almacenamiento con cobro, no control operativo con guardia.',
  },
  {
    name: 'Bikeep plataforma comercial',
    model: 'Ecosistema propietario hardware + software',
    userCost: 'Variable segun operador y plan',
    fit: 'Orientada a modelo comercial, no a flujo especifico UBB.',
  },
];

const methodologySteps = [
  'Analisis del modulo a desarrollar',
  'Diseno de la solucion',
  'Implementacion incremental',
  'Pruebas funcionales por incremento',
  'Evaluacion y ajustes continuos',
  'Integracion progresiva del sistema',
];

const activities = [
  {
    name: 'Actividad 1',
    title: 'Analisis del proceso actual',
    detail: 'Levantamiento de flujo real, actores y problemas del registro manual.',
  },
  {
    name: 'Actividad 2',
    title: 'Revision de soluciones similares',
    detail: 'Benchmark universitario y comercial para definir diferenciacion UBB.',
  },
  {
    name: 'Actividad 3',
    title: 'Definicion de requisitos',
    detail: 'Requisitos funcionales, no funcionales y reglas de negocio del sistema.',
  },
  {
    name: 'Actividad 4',
    title: 'Desarrollo del MVP',
    detail: 'Construccion multiplataforma de registro, QR y control basico de ingreso/retiro.',
  },
  {
    name: 'Actividad 5',
    title: 'Integracion y evaluacion final',
    detail: 'Historial, incidencias, reportes, pruebas finales e informe de titulacion.',
  },
];

const roadPhases = [
  {
    period: 'Abril - Julio',
    focus: 'Definicion de requisitos, diseno UX y desarrollo del MVP multiplataforma.',
  },
  {
    period: 'Agosto - Octubre',
    focus: 'Integracion de historial, incidencias, trazabilidad y reportes administrativos.',
  },
  {
    period: 'Noviembre - Diciembre',
    focus: 'Pruebas finales, ajustes de integracion, informe final y defensa del proyecto.',
  },
];

const schedule = [
  {
    period: 'Marzo - Abril 2026',
    focus: 'Analisis inicial, benchmark y definicion de requisitos.',
  },
  {
    period: 'Mayo - Julio 2026',
    focus: 'Diseno e implementacion del producto minimo viable.',
  },
  {
    period: 'Agosto - Octubre 2026',
    focus: 'Integracion de modulos administrativos, reportes y trazabilidad.',
  },
  {
    period: 'Noviembre - Diciembre 2026',
    focus: 'Pruebas integrales, ajustes finales, informe y defensa.',
  },
];

const impact = [
  {
    metric: 'Atencion mas rapida',
    detail: 'Menos tiempo por operacion gracias al QR y datos precargados del usuario.',
  },
  {
    metric: 'Menor error humano',
    detail: 'Validaciones digitales para evitar registros incompletos o inconsistentes.',
  },
  {
    metric: 'Trazabilidad total',
    detail: 'Cada movimiento queda asociado a usuario, bicicleta, guardia, fecha y hora.',
  },
  {
    metric: 'Continuidad operativa',
    detail: 'Estado del bicicletero visible en tiempo real, incluso con rotacion de guardias.',
  },
];

const references = [
  {
    label: 'UdeC | Enrolamiento para bicicleteros',
    href: 'https://vraeaweb.udec.cl/servicios/enrolamiento-para-bicicleteros/',
  },
  {
    label: 'University of Houston | Bikeep CougarSAFE',
    href: 'https://www.uh.edu/cougarsafe/bikeep/index.php',
  },
  {
    label: 'UC Davis | Bicycle Program',
    href: 'https://transportation.ucdavis.edu/bicycleprogram',
  },
  {
    label: 'Bikeep | Smart bike parking platform',
    href: 'https://bikeep.com/rent-smart-bike-parking-station',
  },
  {
    label: 'App Store | UdeCMovil',
    href: 'https://apps.apple.com/cl/app/udecm%C3%B3vil/id6670761228',
  },
  {
    label: 'App Store | UH Go',
    href: 'https://apps.apple.com/us/app/uh-go/id1350490089',
  },
];
---

<Layout
  title="BiciUBB Control | Propuesta de Proyecto"
  description="Aplicacion multiplataforma para optimizar el ingreso y retiro de bicicletas en la Universidad del Bio-Bio."
>
  <header class="site-header">
    <div class="container nav">
      <a class="brand" href="#inicio">
        <span class="brand-mark">B</span>
        <span>BiciUBB Control</span>
      </a>

      <nav aria-label="Secciones">
        <a href="#problema">Problema</a>
        <a href="#solucion">Solucion</a>
        <a href="#modulos">Modulos</a>
        <a href="#actores">Actores</a>
        <a href="#reglas">Reglas</a>
        <a href="#arquitectura">Arquitectura</a>
        <a href="#stack">Stack</a>
        <a href="#comparativa">Comparativa</a>
        <a href="#metodologia">Metodologia</a>
        <a href="#impacto">Impacto</a>
        <a href="#objetivos">Objetivos</a>
        <a href="#roadmap">Roadmap</a>
        <a href="#referencias">Referencias</a>
      </nav>
    </div>
  </header>

  <main id="inicio">
    <section class="hero container">
      <p class="eyebrow">Propuesta de titulacion IECI | Universidad del Bio-Bio</p>
      <h1>Plataforma de control y trazabilidad para bicicleteros UBB</h1>
      <p class="lead">
        Aplicacion multiplataforma orientada a estudiantes, funcionarios y guardias para reemplazar
        el registro manual por un flujo digital con QR y trazabilidad operativa en tiempo real.
      </p>
      <p class="status-note">Estado: propuesta funcional validada para desarrollo incremental 2026.</p>

      <div class="hero-actions">
        <a class="btn btn-primary" href="#solucion">Ver propuesta</a>
        <a class="btn btn-outline" href="#roadmap">Ver plan 2026</a>
      </div>

      <div class="stats">
        <article>
          <strong>2</strong>
          <span>bicicleteros operativos analizados</span>
        </article>
        <article>
          <strong>9</strong>
          <span>funcionalidades base definidas</span>
        </article>
        <article>
          <strong>1</strong>
          <span>MVP multiplataforma primer semestre</span>
        </article>
      </div>
    </section>

    <section id="problema" class="section container">
      <div class="section-head">
        <p class="tag">Contexto actual</p>
        <h2>El modelo actual limita velocidad de atencion y control operativo</h2>
      </div>
      <div class="grid two">
        {painPoints.map((item) => (
          <article class="card">
            <p>{item}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="solucion" class="section container">
      <div class="section-head">
        <p class="tag">Solucion propuesta</p>
        <h2>Digitalizacion del flujo sin perder validacion humana en terreno</h2>
      </div>
      <ol class="flow">
        {workflow.map((step, idx) => (
          <li>
            <span>{idx + 1}</span>
            <p>{step}</p>
          </li>
        ))}
      </ol>
    </section>

    <section id="modulos" class="section container">
      <div class="section-head">
        <p class="tag">Alcance funcional</p>
        <h2>Capacidades funcionales priorizadas para el MVP y la fase de expansion</h2>
      </div>
      <div class="grid three">
        {modules.map((module) => (
          <article class="card module">
            <p>{module}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="actores" class="section container">
      <div class="section-head">
        <p class="tag">Actores del sistema</p>
        <h2>Roles operativos que participan en el flujo diario de bicicleteros</h2>
      </div>
      <div class="grid two actors">
        {actors.map((actor) => (
          <article class="card actor-card">
            <h3>{actor.role}</h3>
            <p>
              <strong>Rol operativo:</strong> {actor.action}
            </p>
            <p>
              <strong>Valor esperado:</strong> {actor.value}
            </p>
          </article>
        ))}
      </div>
    </section>

    <section id="reglas" class="section container">
      <div class="section-head">
        <p class="tag">Reglas operativas</p>
        <h2>Lineamientos funcionales que sostienen la trazabilidad del servicio</h2>
      </div>
      <ol class="rules">
        {businessRules.map((rule, idx) => (
          <li>
            <span>{idx + 1}</span>
            <p>{rule}</p>
          </li>
        ))}
      </ol>
    </section>

    <section id="arquitectura" class="section container">
      <div class="section-head">
        <p class="tag">Arquitectura funcional</p>
        <h2>Capas definidas para sostener operacion diaria y crecimiento del sistema</h2>
      </div>
      <div class="architecture">
        {architectureLayers.map((item, idx) => (
          <article class="arch-item">
            <span class="arch-index">{idx + 1}</span>
            <div>
              <h3>{item.layer}</h3>
              <p>{item.description}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section id="stack" class="section container">
      <div class="section-head">
        <p class="tag">Stack tecnologico propuesto</p>
        <h2>Base tecnica preliminar alineada con alcance de titulacion 2026</h2>
        <p class="stack-note">
          La seleccion final del stack se tomara en funcion de los requisitos funcionales, no
          funcionales y restricciones tecnicas detectadas en la etapa de analisis.
        </p>
      </div>
      <div class="grid two">
        {proposedStack.map((item) => (
          <article class="card stack-card">
            <h3>{item.block}</h3>
            <p>
              <strong>Propuesta:</strong> {item.option}
            </p>
            <p>
              <strong>Justificacion:</strong> {item.reason}
            </p>
          </article>
        ))}
      </div>
    </section>

    <section id="comparativa" class="section container">
      <div class="section-head">
        <p class="tag">Analisis comparativo</p>
        <h2>Benchmark de referencia para definir una solucion ajustada al contexto UBB</h2>
      </div>
      <div class="grid two comparison">
        {benchmark.map((item) => (
          <article class="card comparison-item">
            <h3>{item.name}</h3>
            <p>
              <strong>Modelo:</strong> {item.model}
            </p>
            <p>
              <strong>Costo usuario:</strong> {item.userCost}
            </p>
            <p>
              <strong>Diferencia clave:</strong> {item.fit}
            </p>
          </article>
        ))}
      </div>
    </section>

    <section id="objetivos" class="section container">
      <div class="section-head">
        <p class="tag">Objetivos del proyecto</p>
        <h2>Mejora de operacion diaria y soporte de gestion administrativa</h2>
      </div>
      <div class="grid two">
        <article class="card">
          <h3>Objetivo general</h3>
          <p>
            Analizar, disenar e implementar una solucion software multiplataforma para optimizar el
            ingreso y retiro de bicicletas con identificacion QR y registro digital.
          </p>
        </article>
        <article class="card">
          <h3>Resultados esperados</h3>
          <ul>
            <li>Menor tiempo de atencion en accesos y retiros.</li>
            <li>Menos errores de registro y mejor continuidad operativa.</li>
            <li>Mayor trazabilidad por usuario, bicicleta, guardia y horario.</li>
          </ul>
        </article>
      </div>
    </section>

    <section id="metodologia" class="section container">
      <div class="section-head">
        <p class="tag">Metodologia de desarrollo</p>
        <h2>Implementacion incremental iterativa para validar valor en cada fase</h2>
      </div>

      <div class="method-grid">
        {methodologySteps.map((step, idx) => (
          <article class="method-step">
            <span>{idx + 1}</span>
            <p>{step}</p>
          </article>
        ))}
      </div>

      <div class="section-head section-gap">
        <p class="tag">Actividades principales</p>
        <h2>Ejecucion por objetivos especificos del proyecto de titulo</h2>
      </div>
      <div class="grid two">
        {activities.map((act) => (
          <article class="card activity-card">
            <p class="activity-label">{act.name}</p>
            <h3>{act.title}</h3>
            <p>{act.detail}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="roadmap" class="section container">
      <div class="section-head">
        <p class="tag">Plan de trabajo 2026</p>
        <h2>Roadmap por fases con entregables tecnicos y academicos</h2>
      </div>
      <div class="timeline">
        {roadPhases.map((phase, idx) => (
          <article class="timeline-item">
            <span class="phase-index">{idx + 1}</span>
            <div>
              <h3>{phase.period}</h3>
              <p>{phase.focus}</p>
            </div>
          </article>
        ))}
      </div>

      <div class="schedule">
        {schedule.map((item) => (
          <article>
            <h3>{item.period}</h3>
            <p>{item.focus}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="impacto" class="section container">
      <div class="section-head">
        <p class="tag">Impacto esperado</p>
        <h2>Resultados esperados para usuarios, seguridad y administracion institucional</h2>
      </div>
      <div class="grid two">
        {impact.map((item) => (
          <article class="card impact-card">
            <h3>{item.metric}</h3>
            <p>{item.detail}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section container">
      <article class="cta-panel">
        <p class="tag">Cierre de propuesta</p>
        <h2>BiciUBB Control plantea una evolucion digital realista del servicio actual</h2>
        <p>
          La propuesta prioriza reutilizar la infraestructura existente de bicicleteros, mantener
          la validacion asistida por guardias y agregar trazabilidad digital para una gestion mas
          segura, rapida y medible durante 2026.
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="#inicio">Volver al inicio</a>
          <a class="btn btn-outline" href="#metodologia">Revisar metodologia</a>
        </div>
      </article>
    </section>

    <section id="referencias" class="section container">
      <div class="section-head">
        <p class="tag">Referencias principales</p>
        <h2>Fuentes utilizadas para el analisis comparativo del proyecto</h2>
      </div>
      <div class="refs">
        {references.map((ref, idx) => (
          <a class="ref-item" href={ref.href} target="_blank" rel="noreferrer">
            <span>[{idx + 1}]</span>
            <p>{ref.label}</p>
          </a>
        ))}
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>BiciUBB Control | Sebastian Alexander Pinto Rivera | IECI UBB | 2026</p>
    </div>
  </footer>
</Layout>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 30;
    backdrop-filter: blur(14px);
    background: rgb(244 247 251 / 76%);
    border-bottom: 1px solid var(--line);
  }

  .nav {
    min-height: 74px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  .brand-mark {
    width: 34px;
    height: 34px;
    border-radius: 10px;
    display: grid;
    place-items: center;
    color: white;
    background: linear-gradient(145deg, var(--primary), #0d678f);
    box-shadow: var(--shadow);
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  nav a {
    text-decoration: none;
    font-size: 0.95rem;
    padding: 0.42rem 0.75rem;
    border-radius: 999px;
    color: var(--muted);
  }

  nav a:hover {
    color: var(--ink);
    background: rgb(11 75 111 / 10%);
  }

  .hero {
    padding: 4.7rem 0 2rem;
  }

  .eyebrow {
    display: inline-flex;
    margin: 0;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--primary);
    font-weight: 700;
  }

  h1 {
    margin: 0.75rem 0 0;
    max-width: 20ch;
    font-size: clamp(2rem, 4.5vw, 3.6rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
  }

  .lead {
    max-width: 68ch;
    color: var(--muted);
    font-size: 1.06rem;
    margin-top: 1rem;
  }

  .status-note {
    margin: 0.85rem 0 0;
    color: var(--primary-strong);
    font-size: 0.92rem;
    font-weight: 600;
  }

  .hero-actions {
    margin-top: 1.6rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .btn {
    text-decoration: none;
    border-radius: 11px;
    font-weight: 600;
    padding: 0.72rem 1.1rem;
    transition: transform 140ms ease;
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .btn-primary {
    background: linear-gradient(145deg, var(--primary), var(--primary-strong));
    color: #fff;
  }

  .btn-outline {
    border: 1px solid var(--line);
    color: var(--ink);
    background: #fff;
  }

  .stats {
    margin-top: 1.9rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.95rem;
  }

  .stats article {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1rem;
    display: grid;
    gap: 0.25rem;
  }

  .stats strong {
    font-size: 1.8rem;
    color: var(--primary);
  }

  .stats span {
    color: var(--muted);
    font-size: 0.92rem;
  }

  .section {
    padding: 2rem 0;
  }

  .section-head {
    margin-bottom: 1rem;
  }

  .tag {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.77rem;
    color: var(--accent);
    font-weight: 700;
  }

  h2 {
    margin: 0.5rem 0 0;
    font-size: clamp(1.45rem, 3vw, 2.1rem);
    line-height: 1.2;
    max-width: 30ch;
  }

  .grid {
    display: grid;
    gap: 1rem;
