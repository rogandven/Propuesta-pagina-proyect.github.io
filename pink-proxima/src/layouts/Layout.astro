---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'UBBike | Propuesta de Proyecto',
  description = 'Aplicacion multiplataforma para control y trazabilidad del ingreso y retiro de bicicletas en los bicicleteros de la Universidad del Bio-Bio.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg: #0e2236;
    --surface: #e7eef6;
    --ink: #0b2f4a;
    --muted: #35506a;
    --primary: #0f5a8b;
    --primary-strong: #0a2d4a;
    --accent: #3dc2af;
    --line: #b9cde0;
    --shadow: 0 16px 40px rgb(10 45 74 / 12%);
    --radius: 18px;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    min-height: 100%;
    background:
      radial-gradient(1280px 660px at 105% -10%, rgb(61 194 175 / 16%), transparent),
      radial-gradient(900px 460px at -15% 8%, rgb(15 90 139 / 26%), transparent),
      linear-gradient(180deg, #0e2236 0%, #0c1d30 100%);
    color: #e4f0fb;
    font-family: 'Manrope', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
    line-height: 1.55;
    scroll-behavior: smooth;
  }

  a {
    color: inherit;
  }

  .container {
    width: min(1120px, 92%);
    margin-inline: auto;
  }
</style>

